# QueueLens configuration — copy to .env and adjust.
# Every variable is optional; defaults shown. Real environment variables
# (docker-compose `environment:`, Kubernetes env, shell exports) always win
# over this file.

# ── Identity & auth ─────────────────────────────────────────────────────────
QUEUELENS_APP_NAME=QueueLens
QUEUELENS_ENVIRONMENT=development
QUEUELENS_AUTH_ENABLED=true
QUEUELENS_ADMIN_USERNAME=admin
QUEUELENS_ADMIN_PASSWORD=change-me            # change this!
# Extra accounts (more can be invited from the UI):
QUEUELENS_USERS_JSON={"sre-oncall": "another-strong-password"}

# ── Default broker (the "development" environment) ─────────────────────────
QUEUELENS_RABBITMQ_URL=amqp://queuelens:queuelens@rabbitmq:5672/
QUEUELENS_RABBITMQ_MANAGEMENT_URL=http://rabbitmq:15672
QUEUELENS_RABBITMQ_MANAGEMENT_USERNAME=queuelens
QUEUELENS_RABBITMQ_MANAGEMENT_PASSWORD=queuelens
QUEUELENS_RABBITMQ_VHOST=/
QUEUELENS_RABBITMQ_CONNECTION_NAME=queuelens
QUEUELENS_RABBITMQ_OPERATION_TIMEOUT_SECONDS=10

# ── Additional environments (each may have its own broker + credentials) ───
# Omitted fields inherit the default broker above. Same-broker environments
# and extra vhosts can also be added at runtime from Configuration → Environments.
QUEUELENS_ENVIRONMENTS_JSON={"staging": {"rabbitmq_url": "amqp://stg-user:stg-pass@rabbitmq-stg:5672/", "management_url": "http://rabbitmq-stg:15672", "management_username": "stg-user", "management_password": "stg-pass", "vhosts": ["/", "staging"]}, "production": {"rabbitmq_url": "amqp://prod-user:prod-pass@rabbitmq-prod:5672/", "management_url": "https://rabbitmq-prod:15672", "management_username": "prod-monitor", "management_password": "prod-monitor-pass", "vhosts": ["orders", "payments", "billing"]}}

# ── Storage & limits ────────────────────────────────────────────────────────
QUEUELENS_DATABASE_URL=sqlite+aiosqlite:///./data/queuelens.db
QUEUELENS_MAX_PREVIEW_MESSAGES=100
QUEUELENS_MAX_MESSAGE_SIZE_BYTES=1048576
QUEUELENS_REFETCH_WINDOW_SIZE=100
QUEUELENS_MAX_BULK_SIZE=500
QUEUELENS_BULK_DRY_RUN_TTL_SECONDS=600
QUEUELENS_REPLAY_TARGETS_JSON={}

# ── Payload masking ─────────────────────────────────────────────────────────
QUEUELENS_MASKING_ENABLED=true
QUEUELENS_MASKED_FIELDS=password,token,access_token,refresh_token,authorization,api_key,secret,email,phone

# ── Alerting & email ────────────────────────────────────────────────────────
QUEUELENS_ALERT_INTERVAL_SECONDS=15
# Seeds the email delivery channel on first boot; editable later in
# Alerts → Delivery Channels (incl. SMTP username/password + TLS for
# authenticated providers). Leave empty to run without email entirely.
QUEUELENS_SMTP_HOST=mailpit
QUEUELENS_SMTP_PORT=1025
